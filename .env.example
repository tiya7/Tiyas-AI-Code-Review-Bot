# ─── Claude PR Reviewer — Environment Variables ───────────────────────────────
# Copy this to .env and fill in your real values.
# NEVER commit .env to git.

# Required: Anthropic API key (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Required: GitHub Personal Access Token
# Needs scopes: repo (full) or at minimum: pull_requests:write, issues:write
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Required: Target repo and PR (auto-set by GitHub Actions, needed only for local runs)
GITHUB_REPOSITORY=owner/repo-name
PR_NUMBER=1

# Optional: Claude model to use
CLAUDE_MODEL=claude-opus-4-5

# Optional: Max characters of diff to send per file (default 12000)
MAX_DIFF_CHARS=12000
